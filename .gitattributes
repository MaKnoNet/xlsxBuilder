# Einheitlich LF im Repository; Checkout passt sich dem OS an.
* text=auto

# Java und Build-Dateien immer LF
*.java    text eol=lf
*.gradle  text eol=lf
*.xml     text eol=lf
*.prefs   text eol=lf
*.md      text eol=lf

# gradlew muss auf Linux/Mac ausführbar bleiben (LF zwingend)
gradlew   text eol=lf

# Windows-Batch bleibt CRLF
*.bat     text eol=crlf

# Binärdateien – keine Zeilenenden-Konvertierung
*.jar     binary
*.zip     binary
*.xlsx    binary

# Team-Git-Hooks: immer LF, sonst scheitert sh unter Git fuer Windows
.githooks/* text eol=lf
